# Runtime environment for the docs site.
#
# These are read on the server at runtime — NOT inlined into the browser bundle.
# This repo bans NEXT_PUBLIC_* on purpose: those are baked in at build time, so the
# same image could not serve qa and prod. Keep config server-side and runtime-read.
#
# In ECS, the real values come from the task definition (Terraform / aws-infra);
# secrets like OPENAI_API_KEY are injected from AWS Secrets Manager. Copy this
# to `.env.local` for local dev.

# Server-side base URL for the site. Read by lib/site-url.ts.
SITE_URL=https://docs.unerr.dev

# Optional. Enables the Ask-AI docs search. Leave blank to disable the feature.
# In ECS this is injected at runtime from Secrets Manager — never commit a real key.
OPENAI_API_KEY=

# Optional override for the Ask-AI model (OpenAI / ChatGPT).
OPENAI_MODEL=gpt-4o-mini

# ── Build-time only (CI / Docker build) ──────────────────────────────────────
# Skip env validation during the build (no secrets are present in CI).
SKIP_ENV_VALIDATION=1
# Turn off Next.js telemetry.
NEXT_TELEMETRY_DISABLED=1
