#!/bin/sh
# unerr installer — https://raw.githubusercontent.com/unerr-ai/unerr-docs/main/install
# Usage: curl -fsSL https://raw.githubusercontent.com/unerr-ai/unerr-docs/main/install | bash
#        VERSION=0.3.5 curl -fsSL https://raw.githubusercontent.com/unerr-ai/unerr-docs/main/install | bash
#        curl -fsSL https://raw.githubusercontent.com/unerr-ai/unerr-docs/main/install | bash -s -- --version 0.3.5
#
# Env overrides:
#   VERSION            — pin a specific release tag (without leading v)
#   UNERR_INSTALL_DIR  — override install location (default: $HOME/.unerr/bin)

set -eu

# Public host for binary Releases + this script (unerr-cli is private, so its
# own Release assets aren't anonymously downloadable). Binaries are published as
# Releases on unerr-docs; this script is served from its raw URL.
REPO="unerr-ai/unerr-docs"
BINARY="unerr"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

say() { printf '\033[1m[unerr]\033[0m %s\n' "$*" >&2; }
err() { printf '\033[31m[unerr] error:\033[0m %s\n' "$*" >&2; exit 1; }

need() {
    command -v "$1" >/dev/null 2>&1 || err "required command not found: $1"
}

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

REQUESTED_VERSION=""
while [ $# -gt 0 ]; do
    case "$1" in
        --version)
            shift
            REQUESTED_VERSION="${1:-}"
            ;;
        --version=*)
            REQUESTED_VERSION="${1#--version=}"
            ;;
        *)
            err "unknown argument: $1"
            ;;
    esac
    shift
done

# $VERSION env takes lowest precedence (flag wins)
if [ -z "$REQUESTED_VERSION" ] && [ -n "${VERSION:-}" ]; then
    REQUESTED_VERSION="$VERSION"
fi

# ---------------------------------------------------------------------------
# Detect OS
# ---------------------------------------------------------------------------

OS="$(uname -s)"
case "$OS" in
    Darwin) OS="darwin" ;;
    Linux)  OS="linux"  ;;
    *)      err "unsupported operating system: $OS (supported: macOS, Linux)" ;;
esac

# ---------------------------------------------------------------------------
# Detect musl (Alpine / musl-libc) — no cozo native prebuild available
# ---------------------------------------------------------------------------

if [ "$OS" = "linux" ]; then
    # ldd prints the libc interpreter; musl includes the word "musl"
    LIBC_INFO="$(ldd --version 2>&1 || true)"
    if printf '%s' "$LIBC_INFO" | grep -qi musl; then
        err "musl/Alpine Linux is not supported by the native binary (no cozo prebuild).
  Use the npm path instead:
    npm install -g @unerr-ai/unerr
  or:
    npx @unerr-ai/unerr"
    fi
    # Secondary check: musl dynamic linker present
    if ls /lib/ld-musl-* >/dev/null 2>&1; then
        err "musl/Alpine Linux is not supported by the native binary (no cozo prebuild).
  Use the npm path instead:
    npm install -g @unerr-ai/unerr
  or:
    npx @unerr-ai/unerr"
    fi
fi

# ---------------------------------------------------------------------------
# Detect arch
# ---------------------------------------------------------------------------

ARCH="$(uname -m)"
case "$ARCH" in
    x86_64 | amd64)  ARCH="x64"   ;;
    aarch64 | arm64) ARCH="arm64" ;;
    *)               err "unsupported architecture: $ARCH (supported: x86_64, aarch64)" ;;
esac

TARGET="${OS}-${ARCH}"
say "detected platform: $TARGET"

# ---------------------------------------------------------------------------
# Resolve version
# ---------------------------------------------------------------------------

need curl

if [ -z "$REQUESTED_VERSION" ]; then
    say "resolving latest release..."
    RELEASE_JSON="$(curl -fsSL "https://api.github.com/repos/${REPO}/releases/latest")"
    # Extract tag_name with sed (no jq dependency)
    TAG="$(printf '%s' "$RELEASE_JSON" | sed -n 's/.*"tag_name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -1)"
    [ -n "$TAG" ] || err "could not resolve latest release tag from GitHub API"
    VERSION_NUM="${TAG#v}"
else
    VERSION_NUM="${REQUESTED_VERSION#v}"
    TAG="v${VERSION_NUM}"
fi

say "installing unerr ${TAG}"

# ---------------------------------------------------------------------------
# Compute asset names
# ---------------------------------------------------------------------------

ARCHIVE="${BINARY}-${TARGET}.tar.gz"
BASE_URL="https://github.com/${REPO}/releases/download/${TAG}"
ARCHIVE_URL="${BASE_URL}/${ARCHIVE}"
SUMS_URL="${BASE_URL}/SHA256SUMS"

# ---------------------------------------------------------------------------
# Install directory
# ---------------------------------------------------------------------------

if [ -n "${UNERR_INSTALL_DIR:-}" ]; then
    INSTALL_DIR="$UNERR_INSTALL_DIR"
elif [ -n "${XDG_BIN_HOME:-}" ]; then
    INSTALL_DIR="$XDG_BIN_HOME"
else
    INSTALL_DIR="${HOME}/.unerr/bin"
fi

mkdir -p "$INSTALL_DIR"

# ---------------------------------------------------------------------------
# Temp dir + cleanup trap
# ---------------------------------------------------------------------------

TMP_DIR="$(mktemp -d)"
cleanup() { rm -rf "$TMP_DIR"; }
trap cleanup EXIT INT TERM

# ---------------------------------------------------------------------------
# Download
# ---------------------------------------------------------------------------

say "downloading ${ARCHIVE}..."
curl -fsSL --progress-bar -o "${TMP_DIR}/${ARCHIVE}" "$ARCHIVE_URL" || \
    err "download failed: ${ARCHIVE_URL}"

say "downloading SHA256SUMS..."
curl -fsSL -o "${TMP_DIR}/SHA256SUMS" "$SUMS_URL" || \
    err "download failed: ${SUMS_URL}"

# ---------------------------------------------------------------------------
# Verify checksum
# ---------------------------------------------------------------------------

say "verifying checksum..."
EXPECTED="$(grep " ${ARCHIVE}$" "${TMP_DIR}/SHA256SUMS" | awk '{print $1}')"
[ -n "$EXPECTED" ] || err "no checksum entry for ${ARCHIVE} in SHA256SUMS"

# Use sha256sum (Linux) or shasum (macOS)
if command -v sha256sum >/dev/null 2>&1; then
    ACTUAL="$(sha256sum "${TMP_DIR}/${ARCHIVE}" | awk '{print $1}')"
else
    need shasum
    ACTUAL="$(shasum -a 256 "${TMP_DIR}/${ARCHIVE}" | awk '{print $1}')"
fi

if [ "$ACTUAL" != "$EXPECTED" ]; then
    err "checksum mismatch for ${ARCHIVE}
  expected: $EXPECTED
  actual:   $ACTUAL"
fi
say "checksum OK"

# ---------------------------------------------------------------------------
# Extract
# ---------------------------------------------------------------------------

say "extracting..."
tar -xzf "${TMP_DIR}/${ARCHIVE}" -C "$TMP_DIR"
[ -f "${TMP_DIR}/${BINARY}" ] || err "archive did not contain a file named '${BINARY}'"

chmod +x "${TMP_DIR}/${BINARY}"
mv "${TMP_DIR}/${BINARY}" "${INSTALL_DIR}/${BINARY}"

say "installed to ${INSTALL_DIR}/${BINARY}"

# ---------------------------------------------------------------------------
# PATH handling
# ---------------------------------------------------------------------------

# Check if the install dir is already on PATH
case ":${PATH}:" in
    *":${INSTALL_DIR}:"*) ON_PATH=1 ;;
    *)                    ON_PATH=0 ;;
esac

if [ "$ON_PATH" = "0" ]; then
    EXPORT_LINE="export PATH=\"${INSTALL_DIR}:\$PATH\""

    # Detect shell and pick rc file
    SHELL_NAME="$(basename "${SHELL:-sh}")"
    case "$SHELL_NAME" in
        zsh)  RC_FILE="${ZDOTDIR:-$HOME}/.zshrc" ;;
        fish)
            RC_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/fish/config.fish"
            EXPORT_LINE="fish_add_path \"${INSTALL_DIR}\""
            ;;
        *)    RC_FILE="$HOME/.bashrc" ;;
    esac

    # Idempotent append — skip if the line is already present
    if [ ! -f "$RC_FILE" ] || ! grep -qF "$INSTALL_DIR" "$RC_FILE" 2>/dev/null; then
        mkdir -p "$(dirname "$RC_FILE")"
        printf '\n# unerr installer\n%s\n' "$EXPORT_LINE" >> "$RC_FILE"
        say "added ${INSTALL_DIR} to PATH in ${RC_FILE}"
    fi

    printf '\n\033[33m[unerr]\033[0m %s is not on your PATH yet.\n' "$INSTALL_DIR" >&2
    printf '        Restart your shell or run:\n' >&2
    printf '          %s\n\n' "$EXPORT_LINE" >&2
else
    say "${INSTALL_DIR} is already on PATH"
fi

# ---------------------------------------------------------------------------
# Done
# ---------------------------------------------------------------------------

printf '\n\033[32m[unerr]\033[0m unerr %s installed successfully!\n' "$TAG" >&2
printf '\n  Next step:\n' >&2
printf '    unerr install claude-code\n\n' >&2
