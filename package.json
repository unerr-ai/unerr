{
  "name": "unerr-docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.26.2",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "predev": "fumadocs-mdx",
    "dev": "next dev",
    "prebuild": "fumadocs-mdx",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "fumadocs-mdx && next typegen && tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "postinstall": "fumadocs-mdx",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.71",
    "ai": "^6.0.205",
    "fumadocs-core": "16.10.2",
    "fumadocs-mdx": "14.2.11",
    "fumadocs-ui": "16.10.2",
    "lucide-react": "^1.17.0",
    "mermaid": "^11.15.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/mdx": "^2.0.14",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "postcss": "^8.5.15",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3"
  }
}
